{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MAID Manifest v2",
  "type": "object",
  "required": ["schema", "goal", "validate", "files"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "2"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "temptations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "description": "Task-specific implementation risks paired with the concrete procedure to use instead.",
      "items": { "$ref": "#/definitions/TemptationSpec" }
    },
    "type": {
      "type": "string",
      "enum": ["feature", "fix", "refactor", "snapshot", "system-snapshot"]
    },
    "files": {
      "type": "object",
      "properties": {
        "create": {
          "type": "array",
          "items": { "$ref": "#/definitions/FileSpec" }
        },
        "edit": {
          "type": "array",
          "items": { "$ref": "#/definitions/FileSpec" }
        },
        "read": {
          "type": "array",
          "items": { "type": "string" }
        },
        "delete": {
          "type": "array",
          "items": { "$ref": "#/definitions/DeleteSpec" }
        },
        "snapshot": {
          "type": "array",
          "items": { "$ref": "#/definitions/FileSpec" }
        }
      },
      "additionalProperties": false
    },
    "validate": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "array",
            "items": { "type": "string" }
          }
        ]
      }
    },
    "acceptance": {
      "type": "object",
      "properties": {
        "tests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        },
        "immutable": {
          "type": "boolean",
          "default": true
        }
      },
      "required": ["tests"],
      "additionalProperties": false
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sequence_number": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonically increasing event-log position for this manifest."
    },
    "version_tag": {
      "type": "string",
      "description": "Free-form per-manifest version label (e.g. v2.4.0, release-1)."
    },
    "created": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "properties": {
        "files": {
          "anyOf": [
            { "required": ["create"] },
            { "required": ["edit"] },
            { "required": ["delete"] },
            { "required": ["snapshot"] }
          ]
        }
      }
    }
  ],
  "definitions": {
    "TemptationSpec": {
      "type": "object",
      "required": ["risk", "instead"],
      "properties": {
        "risk": {
          "type": "string",
          "minLength": 1,
          "description": "The concrete shortcut or gaming pattern to avoid."
        },
        "instead": {
          "type": "string",
          "minLength": 1,
          "description": "The concrete procedure to follow instead."
        }
      },
      "additionalProperties": false
    },
    "FileSpec": {
      "type": "object",
      "required": ["path", "artifacts"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["present", "absent"],
          "default": "present"
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/ArtifactSpec" }
        },
        "imports": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Required import modules/symbols that must appear in this file"
        }
      },
      "additionalProperties": false
    },
    "DeleteSpec": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ArtifactSpec": {
      "type": "object",
      "required": ["kind", "name"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["class", "function", "method", "attribute", "interface", "type", "enum", "namespace", "test_function"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": { "$ref": "#/definitions/ArgSpec" }
        },
        "returns": {
          "type": "string"
        },
        "raises": {
          "type": "array",
          "items": { "type": "string" }
        },
        "async": {
          "type": "boolean"
        },
        "bases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "type_parameters": {
          "type": "array",
          "items": { "type": "string" }
        },
        "of": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "test_function_details": {
          "$ref": "#/definitions/TestFunctionDetails"
        },
        "source_scenario": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "setup": { "type": "object" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/TestCaseAction" }
        },
        "expected": { "type": "object" },
        "dependencies": { "type": "object" }
      },
      "additionalProperties": false
    },
    "TestCaseActionSubject": {
      "type": "object",
      "properties": {
        "module": { "type": "string" },
        "export": { "type": "string" },
        "target": {
          "type": "object",
          "properties": {
            "kind": { "type": "string" },
            "value": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "AuthHeader": {
      "type": "object",
      "properties": {
        "type": { "type": "string" }
      },
      "additionalProperties": true
    },
    "TestCaseAction": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ui_interaction", "api_call"]
        },
        "subject": { "$ref": "#/definitions/TestCaseActionSubject" },
        "method": { "type": "string" },
        "endpoint": { "type": "string" },
        "body": { "type": "object" },
        "body_from": { "type": "object" },
        "action": { "type": "string" },
        "value": {},
        "auth_header": { "$ref": "#/definitions/AuthHeader" }
      },
      "additionalProperties": true
    },
    "SetupAction": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "key": { "type": "string" },
        "value": {},
        "defaults": { "type": "string" },
        "target": { "type": "string" }
      },
      "additionalProperties": true
    },
    "Provider": {
      "type": "object",
      "properties": {
        "component": { "type": "string" },
        "props": { "type": "object" }
      },
      "additionalProperties": true
    },
    "TestFunctionDetails": {
      "type": "object",
      "properties": {
        "source_scenario": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "setup": {
          "type": "object",
          "properties": {
            "auth_required": { "type": "boolean" },
            "test_data": { "type": "object" },
            "setup_actions": {
              "type": "array",
              "items": { "$ref": "#/definitions/SetupAction" }
            }
          },
          "additionalProperties": true
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/TestCaseAction" }
        },
        "expected": {
          "type": "object",
          "properties": {
            "response": {
              "type": "object",
              "properties": {
                "status": { "type": "integer" },
                "body_type": { "type": "string" }
              },
              "additionalProperties": true
            },
            "localStorage": { "type": "object" },
            "navigation": {
              "type": "object",
              "properties": {
                "redirect": { "type": "string" }
              },
              "additionalProperties": true
            },
            "ui": {
              "type": "object",
              "properties": {
                "elements_present": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "text_present": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "dependencies": {
          "type": "object",
          "properties": {
            "environment": { "type": "string" },
            "mocks": { "type": "array" },
            "providers": {
              "type": "array",
              "items": { "$ref": "#/definitions/Provider" }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "ArgSpec": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "default": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
