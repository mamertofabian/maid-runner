{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MAID Manifest v2",
  "type": "object",
  "required": ["schema", "goal", "validate", "files"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "2"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["feature", "fix", "refactor", "snapshot", "system-snapshot"]
    },
    "files": {
      "type": "object",
      "properties": {
        "create": {
          "type": "array",
          "items": { "$ref": "#/definitions/FileSpec" }
        },
        "edit": {
          "type": "array",
          "items": { "$ref": "#/definitions/FileSpec" }
        },
        "read": {
          "type": "array",
          "items": { "type": "string" }
        },
        "delete": {
          "type": "array",
          "items": { "$ref": "#/definitions/DeleteSpec" }
        },
        "snapshot": {
          "type": "array",
          "items": { "$ref": "#/definitions/FileSpec" }
        }
      },
      "additionalProperties": false
    },
    "validate": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "array",
            "items": { "type": "string" }
          }
        ]
      }
    },
    "acceptance": {
      "type": "object",
      "properties": {
        "tests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        },
        "immutable": {
          "type": "boolean",
          "default": true
        }
      },
      "required": ["tests"],
      "additionalProperties": false
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "properties": {
        "files": {
          "anyOf": [
            { "required": ["create"] },
            { "required": ["edit"] },
            { "required": ["delete"] },
            { "required": ["snapshot"] }
          ]
        }
      }
    }
  ],
  "definitions": {
    "FileSpec": {
      "type": "object",
      "required": ["path", "artifacts"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["present", "absent"],
          "default": "present"
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/ArtifactSpec" }
        }
      },
      "additionalProperties": false
    },
    "DeleteSpec": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ArtifactSpec": {
      "type": "object",
      "required": ["kind", "name"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["class", "function", "method", "attribute", "interface", "type", "enum", "namespace"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": { "$ref": "#/definitions/ArgSpec" }
        },
        "returns": {
          "type": "string"
        },
        "raises": {
          "type": "array",
          "items": { "type": "string" }
        },
        "async": {
          "type": "boolean"
        },
        "bases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "of": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ArgSpec": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "default": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
